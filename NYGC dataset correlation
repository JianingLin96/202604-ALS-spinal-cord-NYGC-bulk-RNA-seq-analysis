#----1.4 Testing for covariates: PCA analysis----
```{r, message= FALSE}
load("20260311_NYGC_beforeDEG_RINfiltered.RData")
load("20260311_NYGC_RINfiltered_regions_genepairs.RData")

# --------------------------------------------------
# Configuration
# --------------------------------------------------
categorical_vars <- c(
  "Sex",
  "OnsetSite"
)

continuous_vars <- c(
  "RIN",
  "PMI"
)

top_variable_genes <- 2000

outdir_pca <- "20260311_PCA_covariates"
dir.create(outdir_pca, showWarnings = FALSE)

plot_dir <- file.path(outdir_pca, "PCA_plots")
dir.create(plot_dir, showWarnings = FALSE)

# --------------------------------------------------
# Helper 1: Run PCA for one region
# --------------------------------------------------
run_region_pca <- function(region, expr_list, sample_list, top_n = 2000) {
  
  counts <- expr_list[[region]]
  coldata <- sample_list[[region]]
  
  if (is.null(counts) || is.null(coldata)) return(NULL)
  
  coldata <- as.data.frame(coldata)
  coldata <- coldata[colnames(counts), , drop = FALSE]
  
    dds <- DESeqDataSetFromMatrix(
    countData = counts,
    colData = coldata,
    design = ~1
    )
  dds <- dds[rowSums(counts(dds)) > 10, ]
  vsd <- vst(dds, blind = TRUE)
  mat <- assay(vsd)
  
  # Select most variable genes
  vars <- apply(mat, 1, var)
  top_genes <- names(sort(vars, decreasing = TRUE))[1:min(top_n,length(vars))]
  mat_top <- mat[top_genes, ]
  
  # PCA
  pca <- prcomp(t(mat_top), scale. = TRUE)
  pcs <- as.data.frame(pca$x[,1:5])
  pcs$Sample <- rownames(pcs)
  
  meta <- as.data.frame(coldata)
  meta$Sample <- rownames(meta)
  
  df <- left_join(pcs, meta, by="Sample")
  df$Region <- region
  
  # Calculate percentage of variance
  percentVar <- round(100 * (pca$sdev^2 / sum(pca$sdev^2)), 1)
  
  list(
    pca = pca,
    df = df,
    percentVar = percentVar
  )
}

# --------------------------------------------------
# Helper 2: Statistical testing of PCs vs covariates
# --------------------------------------------------

test_pc_assoc <- function(df,vars,type){

  res <- list()

  for(var in vars){

    if(!var %in% colnames(df)) next

    temp <- df %>% filter(!is.na(.data[[var]]))
    if(nrow(temp)<3) next

    if(type=="continuous"){

      for(pc in c("PC1","PC2","PC3")){

        ct <- suppressWarnings(
          cor.test(temp[[pc]],temp[[var]],method="spearman")
        )

        res[[length(res)+1]] <- data.frame(
          PC=pc,
          Variable=var,
          Type="Continuous",
          N=nrow(temp),
          Correlation=unname(ct$estimate),
          Pvalue=ct$p.value
        )
      }

    }else{

      temp[[var]] <- as.factor(temp[[var]])
      if(nlevels(temp[[var]])<2) next

      for(pc in c("PC1","PC2","PC3")){

        fit <- aov(temp[[pc]]~temp[[var]])

        res[[length(res)+1]] <- data.frame(
          PC=pc,
          Variable=var,
          Type="Categorical",
          N=nrow(temp),
          Correlation=NA,
          Pvalue=summary(fit)[[1]][["Pr(>F)"]][1]
        )
      }
    }
  }

  bind_rows(res)
}

# --------------------------------------------------
# Helper 3: Plotting PCA
# --------------------------------------------------

plot_pca_cont <- function(df, var, region, percentVar) {

  ggplot(df, aes(PC1, PC2, color = .data[[var]])) +
    geom_point(size = 3, alpha = 0.9) +
    scale_color_viridis_c() +
    theme_bw(base_size = 13) +
    labs(
      title = paste(region, "| PCA colored by", var),
      x = paste0("PC1: ", percentVar[1], "% variance"),
      y = paste0("PC2: ", percentVar[2], "% variance"),
      color = var
    )
}

plot_pca_cat <- function(df, var, region, percentVar) {

  ggplot(df, aes(PC1, PC2, color = .data[[var]])) +
    geom_point(size = 3, alpha = 0.9) +
    theme_bw(base_size = 13) +
    labs(
      title = paste(region, "| PCA colored by", var),
      x = paste0("PC1: ", percentVar[1], "% variance"),
      y = paste0("PC2: ", percentVar[2], "% variance"),
      color = var
    )
}

save_pca_plots <- function(df,region,percentVar,vars,type){

  for(var in vars){

    if(!var %in% colnames(df)) next

    if(type=="continuous"){
      p <- plot_pca_cont(df,var,region,percentVar)              
    }else{
      p <- plot_pca_cat(df,var,region,percentVar)
    }

    file_name <- paste0(
      region,"_PCA_",
      str_replace_all(var,"[^A-Za-z0-9._-]","_"),
      ".tiff"
    )

    ggsave(
      file.path(plot_dir,file_name),
      p,
      width=7,
      height=5,
      dpi=300
    )
  }
}

# --------------------------------------------------
# Start working!
# --------------------------------------------------

#Run PCA
pca_results <- lapply(region_order,function(region){
  run_region_pca(region,expr_list,sample_list,top_variable_genes)  #Helper 1
})

names(pca_results) <- region_order
pca_results <- pca_results[!sapply(pca_results,is.null)]


pc_assoc_results <- list()

for(region in names(pca_results)){

  df <- pca_results[[region]]$df
  percentVar <- pca_results[[region]]$percentVar

  # association tests
  cont_res <- test_pc_assoc(df,continuous_vars,"continuous")    #Helper 2
  cat_res  <- test_pc_assoc(df,categorical_vars,"categorical")

  region_res <- bind_rows(cont_res,cat_res)
  region_res$Region <- region

  pc_assoc_results[[region]] <- region_res

  # plots
  save_pca_plots(df,region,percentVar,continuous_vars,"continuous")    #Helper 3
  save_pca_plots(df,region,percentVar,categorical_vars,"categorical")

}

#Final results in the table
pc_table <- bind_rows(pc_assoc_results)

if(nrow(pc_table)){
  pc_table <- pc_table %>%
    group_by(PC) %>%
    mutate(Adj.Pvalue=p.adjust(Pvalue,method="BH")) %>%
    ungroup()
}

# --------------------------------------------------
# Save results
# --------------------------------------------------

write.csv(
  pc_table,
  file.path(outdir_pca,"20260311_PCA_covariate_associations.csv"),
  row.names=FALSE
)

save(
  pca_results,
  pc_table,
  categorical_vars,
  continuous_vars,
  file="20260311_PCA_covariate_analysis.RData"
)

message("PCA covariate analysis complete.")
message("Plots saved in: ", plot_dir)
message("Results table saved in: ", outdir_pca)

# --------------------------------------------------
# Variance explained by covariates (variancePartition)
# --------------------------------------------------

library(variancePartition)
library(BiocParallel)

run_variance_partition <- function(
  expr_list,
  sample_list,
  region_order,
  covariates = c("RIN", "PMI", "Sex", "OnsetSite"),
  outdir = ".",
  n_top = 5000,
  min_counts = 10,
  n_cores = 8
) {
  # Packages
  library(DESeq2)
  library(variancePartition)
  library(BiocParallel)
  library(ggplot2)
  library(matrixStats)

  # Parallel backend for variancePartition / DESeq2
  register(SnowParam(n_cores))

  if (!dir.exists(outdir)) dir.create(outdir, recursive = TRUE)

  results <- vector("list", length(region_order))
  names(results) <- region_order

  for (region in region_order) {
    message("===== Region: ", region, " =====")
    counts  <- expr_list[[region]]
    coldata <- sample_list[[region]]
    if (is.null(counts) || is.null(coldata)) {
      message("  Skipped: missing counts or coldata")
      next
    }
    
    # Align samples
    common_samples <- intersect(colnames(counts), rownames(coldata))
    if (length(common_samples) == 0) {
      message("  Skipped: no overlapping samples between counts and coldata")
      next
    }
    counts  <- counts[, common_samples, drop = FALSE]
    coldata <- coldata[common_samples, , drop = FALSE]
    
    # Sanitize column names
    colnames(coldata) <- make.names(colnames(coldata))
    
    # Covariate availability
    available <- covariates[covariates %in% colnames(coldata)]
    missing   <- setdiff(covariates, available)
    if (length(available) == 0) {
      message("  Skipped: no covariates available in this region")
      next
    }
    if (length(missing) > 0) {
      message("  Missing covariates: ", paste(missing, collapse = ", "))
      message("  Using covariates: ", paste(available, collapse = ", "))
    } else {
      message("  Using covariates: ", paste(available, collapse = ", "))
    }
    
    # Build formula
    form_str <- paste("~", paste(available, collapse = " + "))
    form <- as.formula(form_str)
    
    # DESeq2 object
    dds <- DESeqDataSetFromMatrix(
      countData = counts,
      colData = coldata,
      design = ~1
    )
    
    # Filter low counts
    keep <- rowSums(counts(dds)) > min_counts
    dds  <- dds[keep, ]
    if (nrow(dds) == 0) {
      message("  Skipped: no genes pass count filter")
      next
    }
    
    # VST
    vsd  <- vst(dds, blind = TRUE)
    expr <- assay(vsd)
    
    # Top variable genes (fast)
    vars <- rowVars(expr)
    n_top_use <- min(n_top, length(vars))
    top_idx <- order(vars, decreasing = TRUE)[seq_len(n_top_use)]
    expr <- expr[top_idx, , drop = FALSE]
    
    # Validate model matrix
    mm <- model.matrix(form, coldata)
    message("  Model matrix columns: ", paste(colnames(mm), collapse = ", "))
    
    # variancePartition
    varPart <- fitExtractVarPartModel(expr, form, coldata)
    vp <- sortCols(varPart)
    
    # Plot
    p <- plotVarPart(vp) +
      ggtitle(paste("Variance explained |", region))
    outfile <- file.path(outdir, paste0(region, "_variancePartition.tiff"))
    ggsave(
      outfile,
      p,
      width = 7,
      height = 5,
      dpi = 300
    )
    message("  Saved plot: ", outfile)
    results[[region]] <- vp
  }
  invisible(results)
}

varpart_results <- run_variance_partition(
  expr_list = expr_list,
  sample_list = sample_list,
  region_order = region_order,
  covariates = c("RIN", "PMI", "Sex", "OnsetSite"),
  outdir = outdir_pca
)

library(dplyr)
library(tidyr)
library(purrr)

variance_summary <- map_df(
  names(varpart_results),
  function(region) {
    vp <- varpart_results[[region]]
    if (is.null(vp)) return(NULL)
    vp_df <- as.data.frame(vp)
    vp_df$Gene <- rownames(vp_df)
    vp_long <- vp_df %>%
      pivot_longer(
        cols = -Gene,
        names_to = "Covariate",
        values_to = "VarianceExplained"
      ) %>%
      group_by(Covariate) %>%
      summarize(
        MeanVariance = mean(VarianceExplained, na.rm = TRUE),
        .groups = "drop"
      ) %>%
      mutate(Region = region)
    vp_long
  }
)

variance_summary

save(
  varpart_results,
  file="20260311_variancePartition_results.RData"
)

