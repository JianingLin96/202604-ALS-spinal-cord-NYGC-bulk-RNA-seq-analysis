plot_corr_heatmap <- function(summary_table, pair_labels, out_tiff, title_prefix) {
  tab <- summary_table %>% filter(Pair %in% pair_labels)

  # rho
  heat_df <- reshape2::dcast(tab, Region ~ Pair, value.var = "Spearman_rho")
  heat_melt <- reshape2::melt(heat_df, id.vars = "Region",
                    variable.name = "Pair", value.name = "Spearman_rho")

  # FDR
  fdr_df <- reshape2::dcast(tab, Region ~ Pair, value.var = "Spearman_p_adj")
  fdr_melt <- reshape2::melt(fdr_df, id.vars = "Region",
                   variable.name = "Pair", value.name = "Spearman_p_adj")

  heat_melt <- merge(heat_melt, fdr_melt, by = c("Region", "Pair"), sort = FALSE)
  heat_melt$stars <- sapply(heat_melt$Spearman_p_adj, p_to_star)
  heat_melt$rho   <- round(heat_melt$Spearman_rho, 2)
  
  p_heat <- ggplot(heat_melt, aes(x = Pair, y = Region, fill = Spearman_rho)) +
    geom_tile(color = "grey80") +
  # Rho values on top
    geom_text(aes(label = rho), size = 4, color = "black") +
  # Stars slightly below
    geom_text(aes(label = stars), size = 5, color = "black", nudge_y = 0.25) +
    scale_fill_gradient2(low = "#0ABFC4", high = "#F7776E", mid = "white",
                         midpoint = 0, limits = c(-1, 1), na.value = "grey90") +
    labs(title = NULL, 
          x = NULL, y = NULL, fill = "Spearman ρ") +
    theme_minimal(base_size = 10) +
    theme(axis.text.x = element_text(angle = 90, hjust = 1),
          panel.grid = element_blank())

  tiff(out_tiff, width = 15, height = 3, units = "in", res = 300, compression = "lzw")
  print(p_heat); dev.off()

  list(plot = p_heat, heat_data = heat_melt)
}

