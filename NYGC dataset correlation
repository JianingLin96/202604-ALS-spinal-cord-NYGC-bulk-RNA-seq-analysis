#-----------------------------------------
# Universal safe filename helper
#-----------------------------------------
safe_filename <- function(x) gsub("[^A-Za-z0-9._-]+", "_", x)

#-----------------------------------------
# UNIVERSAL Spearman scatter plot helper
#-----------------------------------------
plot_corr_scatter <- function(
    region,
    var1_name, var2_name,
    x, y,
    rho, p, fdr,
    outdir
){
  annotation <- sprintf("ρ = %.2f\np = %.3g\nFDR = %.3g", 
                        as.numeric(rho), as.numeric(p), as.numeric(fdr))

  df <- data.frame(x = x, y = y)

  p_plot <- ggplot(df, aes(x, y)) +
    geom_point(alpha = 0.7) +
    geom_smooth(method = "lm", se = FALSE, color = "red") +
    annotate("text", x = Inf, y = -Inf, label = annotation,
             hjust = 1.1, vjust = -0.5, size = 5) +
    labs(
      title = paste(region, ":", var1_name, "vs", var2_name, "(Spearman)"),
      x = var1_name,
      y = var2_name
    ) +
    theme_bw()

  fname <- paste0(
    safe_filename(region), "_",
    safe_filename(var1_name), "_vs_",
    safe_filename(var2_name), "_Spearman.tiff"
  )

  tryCatch({
    tiff(file.path(outdir, fname), width = 8, height = 8,
         units = "in", res = 300, compression = "lzw")
    print(p_plot)
    dev.off()
  }, error = function(e){
    message("❌ Error saving ", var1_name, " vs ", var2_name, ": ", e$message)
  })

  invisible(p_plot)
}

